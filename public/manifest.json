{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "description": "__MSG_extDescription__",
  "default_locale": "zh_CN",
  "version": "0.0.1",
  "permissions": ["favicon", "search"],
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "host_permissions": [
    "https://www.google.com/s2/favicons*",
    "https://*.gstatic.com/*",
    "https://www.faviconextractor.com/*",
    "https://icon.horse/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
